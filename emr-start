#!/usr/bin/env bash
# Arranque local EMR (backend + frontend). DB Docker opcional.
#
# Variables opcionales:
#   START_DB=true|false        (default: false) — solo servicio db vía compose
#   RUN_MIGRATIONS=true|false  (default: true)
#   RUN_SEED=true|false        (default: false) — seed_data idempotente, no destructivo
#
# Ejemplos:
#   ./emr-start
#   START_DB=true ./emr-start
#   RUN_SEED=true ./emr-start
#   START_DB=true RUN_SEED=true ./emr-start
#   RUN_MIGRATIONS=false ./emr-start
#
# Ver docs/dev-start.md

set -euo pipefail

BASE_DIR="$(cd "$(dirname "$0")" && pwd)"
FRONTEND_DIR="$BASE_DIR/frontend"
LOG_DIR="$BASE_DIR/logs"
PYTHON="$BASE_DIR/emr_env/bin/python"

START_DB="${START_DB:-false}"
RUN_MIGRATIONS="${RUN_MIGRATIONS:-true}"
RUN_SEED="${RUN_SEED:-false}"

mkdir -p "$LOG_DIR"

die() {
  echo "❌ $*" >&2
  exit 1
}

require_cmd() {
  local cmd="$1"
  local hint="${2:-}"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "❌ $cmd no está en PATH." >&2
    [ -n "$hint" ] && echo "   $hint" >&2
    exit 1
  fi
}

docker_compose() {
  if docker compose version >/dev/null 2>&1; then
    docker compose "$@"
  elif command -v docker-compose >/dev/null 2>&1; then
    docker-compose "$@"
  else
    die "docker compose no disponible. Instalá Docker Desktop o el plugin compose."
  fi
}

wait_for_docker_daemon() {
  local timeout="${1:-120}"
  echo "🐳 Esperando daemon Docker (timeout ${timeout}s)..."
  local i
  for i in $(seq 1 "$timeout"); do
    if docker info >/dev/null 2>&1; then
      echo "✅ Docker daemon activo"
      return 0
    fi
    sleep 1
  done
  die "Timeout: Docker no respondió. Iniciá Docker Desktop y reintentá."
}

wait_for_postgres() {
  local timeout="${1:-120}"
  echo "🐘 Esperando Postgres en :5432 (timeout ${timeout}s)..."
  local i
  for i in $(seq 1 "$timeout"); do
    if command -v pg_isready >/dev/null 2>&1; then
      if pg_isready -h 127.0.0.1 -p 5432 -q 2>/dev/null; then
        echo "✅ Postgres disponible (pg_isready)"
        return 0
      fi
    elif lsof -i :5432 >/dev/null 2>&1; then
      echo "✅ Postgres disponible (puerto :5432 en escucha)"
      return 0
    fi
    sleep 1
  done
  die "Timeout: Postgres no responde en :5432. Usá START_DB=true ./emr-start o levantá la DB manualmente."
}

start_db_container() {
  require_cmd docker "Instalá Docker para usar START_DB=true."
  if [ "$(uname -s)" = "Darwin" ]; then
    open -a Docker 2>/dev/null || true
  fi
  wait_for_docker_daemon 120
  echo "🐘 Levantando solo el servicio db (docker compose up -d db)..."
  (cd "$BASE_DIR" && docker_compose up -d db)
}

if [ ! -x "$PYTHON" ]; then
  die "No se encontró el entorno Python en: $PYTHON
   Creá/activá emr_env en la raíz del repo antes de continuar."
fi

if [ ! -f "$FRONTEND_DIR/package.json" ]; then
  die "No se encontró $FRONTEND_DIR/package.json (submódulo frontend?)."
fi

require_cmd node "Instalá Node.js (LTS recomendado) y asegurate de que esté en PATH.
   En macOS con nvm: export NVM_DIR=\"\$HOME/.nvm\" && . \"\$NVM_DIR/nvm.sh\""
require_cmd npm "npm suele venir con Node. Verificá la instalación de Node.js."

if ! command -v npx >/dev/null 2>&1; then
  echo "⚠️  npx no está en PATH (npm start puede seguir funcionando si npm está OK)."
fi

if [ ! -d "$FRONTEND_DIR/node_modules" ]; then
  die "frontend/node_modules ausente.
   Ejecutá: cd frontend && npm install"
fi

if [ "$START_DB" = "true" ]; then
  start_db_container
else
  echo "ℹ️  START_DB=false — no se levanta Docker (asumiendo Postgres ya disponible en :5432)"
fi

wait_for_postgres 120

cd "$BASE_DIR"

if [ "$RUN_MIGRATIONS" = "true" ]; then
  echo "🐍 Ejecutando migraciones (RUN_MIGRATIONS=true)..."
  "$PYTHON" manage.py migrate --noinput
else
  echo "⏭️  Migraciones omitidas (RUN_MIGRATIONS=$RUN_MIGRATIONS)"
fi

if [ "$RUN_SEED" = "true" ]; then
  echo "🌱 Ejecutando seed_data (RUN_SEED=true, idempotente; no usa poblar_db)..."
  "$PYTHON" manage.py seed_data
else
  echo "⏭️  Seed omitido (RUN_SEED=$RUN_SEED; usar RUN_SEED=true para usuarios demo)"
fi

echo "🐍 Iniciando Django en :8000..."
nohup "$PYTHON" manage.py runserver 0.0.0.0:8000 \
  > "$LOG_DIR/backend.log" 2>&1 &
BACKEND_PID=$!

echo "   Esperando backend en :8000..."
for _ in $(seq 1 30); do
  if lsof -i :8000 >/dev/null 2>&1; then
    break
  fi
  sleep 1
done
if ! lsof -i :8000 >/dev/null 2>&1; then
  echo "❌ Django no levantó (PID $BACKEND_PID)" >&2
  tail -n 40 "$LOG_DIR/backend.log" >&2 || true
  exit 1
fi
echo "✅ Django activo (PID $BACKEND_PID)"

echo "⚛️  Iniciando React en :3000..."
cd "$FRONTEND_DIR"
nohup npm start > "$LOG_DIR/frontend.log" 2>&1 &
FRONTEND_PID=$!
cd "$BASE_DIR"

echo "   Esperando frontend en :3000 (puede tardar ~60s)..."
for _ in $(seq 1 90); do
  if lsof -i :3000 >/dev/null 2>&1; then
    break
  fi
  sleep 1
done
if ! lsof -i :3000 >/dev/null 2>&1; then
  echo "❌ React no levantó (PID $FRONTEND_PID)" >&2
  tail -n 40 "$LOG_DIR/frontend.log" >&2 || true
  exit 1
fi
echo "✅ React activo (PID $FRONTEND_PID)"

echo ""
echo "🚀 EMR levantado (entorno local / desarrollo)"
echo "   Backend:  http://localhost:8000  (PID $BACKEND_PID)"
echo "   Admin:    http://localhost:8000/admin/"
echo "   Frontend: http://localhost:3000  (PID $FRONTEND_PID)"
echo ""
if [ "$RUN_SEED" = "true" ]; then
  echo "👤 Usuarios demo (solo desarrollo; ver seed_data):"
  echo "   admin / admin123"
  echo "   medico1 / medico123"
  echo "   paciente1 / paciente123"
  echo "   laboratorio1 / laboratorio123"
  echo "   enfermeria1 / enfermeria123"
  echo "   secretaria1 / secretaria123"
  echo ""
fi
echo "📋 Logs:"
echo "   tail -f $LOG_DIR/backend.log"
echo "   tail -f $LOG_DIR/frontend.log"
echo ""
echo "🛑 Detener: ./stop_servers.sh"
echo ""
echo "⚠️  Seguridad:"
echo "   - Entorno local/dev únicamente."
echo "   - No usar con datos clínicos reales sin respaldo."
echo "   - RUN_SEED=true crea/actualiza usuarios demo; no ejecuta seeds destructivos."
echo "   - Contraseñas de demo son débiles a propósito; no reutilizar en producción."
