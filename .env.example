# SYNESIS EMR/LIMS — variables de entorno (desarrollo local)
# Copiar a .env y ajustar. No commitear secretos reales.

# --- Django core ---
DJANGO_DEBUG=True
DJANGO_RUNTIME=runserver
# Solo desarrollo local; en producción usar get_random_secret_key() o gestor de secretos.
DJANGO_SECRET_KEY=change-me-local-only
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- CORS / CSRF (desarrollo) ---
# En DEBUG=True, CORS puede estar abierto; opcionalmente restringir orígenes:
# DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- HTTPS / cookies (desarrollo HTTP) ---
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
# DJANGO_USE_PROXY_SSL_HEADER=False

# --- Base de datos (desarrollo híbrido: Postgres en Docker emr_postgres) ---
# Una sola BD local: contenedor emr_postgres → localhost:5432
# Levantar con: ./emrctl up
# NO usar synesis_user ni Postgres nativo en WSL (genera bases duplicadas).
DB_ENGINE=django.db.backends.postgresql
DB_NAME=synesis_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# --- Correo (informes LIMS) ---
# Por defecto (sin SMTP) los mails solo se imprimen en la consola del backend.
# Gmail: 2FA + contraseña de aplicación en https://myaccount.google.com/apppasswords
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=tu-cuenta@gmail.com
# EMAIL_HOST_PASSWORD=xxxx xxxx xxxx xxxx
# DEFAULT_FROM_EMAIL=tu-cuenta@gmail.com
# EMAIL_TIMEOUT=15
