# SYNESIS EMR/LIMS — plantilla de producción (sin secretos reales)
# Usar con gestor de secretos / variables del orquestador. No commitear valores reales.

DJANGO_DEBUG=False
DJANGO_RUNTIME=gunicorn
# Generar fuera del repo. No usar este placeholder.
# Ejemplo de comando:
# python - <<'PY'
# from django.core.management.utils import get_random_secret_key
# print(get_random_secret_key())
# PY
DJANGO_SECRET_KEY=REEMPLAZAR_CON_SECRETO_ALEATORIO_DE_50+_CARACTERES_NO_COMMITEAR
DJANGO_ALLOWED_HOSTS=app.example.com,api.example.com
# Host para header Host del healthcheck interno (debe estar incluido en DJANGO_ALLOWED_HOSTS)
DJANGO_HEALTHCHECK_HOST=localhost

# Orígenes explícitos (obligatorios con DEBUG=False)
DJANGO_CORS_ALLOWED_ORIGINS=https://app.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.example.com,https://api.example.com

# No habilitar CORS abierto en producción
# DJANGO_CORS_ALLOW_ALL_ORIGINS=False

# HTTPS detrás de proxy / TLS terminado (PROD-3: Nginx o balanceador externo)
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_USE_PROXY_SSL_HEADER=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# DJANGO_SECURE_HSTS_PRELOAD=False

# --- Reverse proxy (PROD-3) ---
# Plantilla Nginx: deploy/nginx/nginx.prod.example.conf
# DJANGO_ALLOWED_HOSTS debe incluir el host público (p. ej. example.com) y DJANGO_HEALTHCHECK_HOST.
# DJANGO_CSRF_TRUSTED_ORIGINS debe listar orígenes HTTPS del frontend (p. ej. https://app.example.com).
# TLS: responsabilidad del Nginx/balanceador; no commitear certificados reales.
# NGINX_SERVER_NAME=example.com  # editar en nginx.prod.example.conf al desplegar

# --- Storage privado / media clínica (PROD-4) ---
# MEDIA_ROOT permanece en disco del contenedor backend (o volumen interno Docker).
# No servir /media/ desde Nginx ni Django con DEBUG=False.
# Descargas: endpoints autenticados (/api/archivos-medicos/.../download/, /api/documentos/.../download/, etc.).
# S3/MinIO/object storage privado: fase posterior; no commitear credenciales cloud aquí.
# Backups: plantillas PROD-5 en deploy/backup/ — salida fuera del repo (BACKUP_DIR); no commitear dumps ni tarballs.

# --- Base de datos ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=synesis_db
DB_USER=synesis_app
DB_PASSWORD=change-me
DB_HOST=db.internal
DB_PORT=5432

# Docker dev usa RUN_MIGRATIONS; en producción usar job de migración controlado
# RUN_MIGRATIONS=false
